---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';
import { getImage } from 'astro:assets';
import forestBgSrc from '../assets/images/forest-bg.webp';
import { navLinks } from '../data/nav-links';
import { colorBg } from '../data/theme';
import cssText from '../styles/global.css?inline';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  ogImageAlt?: string;
  noindex?: boolean;
  preloadImages?: { srcset: string; sizes: string; type: string }[];
}

const {
  title = 'Old Forest Echoes',
  description = 'Old Forest Echoes — music and art composed in Finnish old-growth forests by Barbora Xu, raising awareness to protect threatened forests.',
  ogImage = '/images/og-image-landscape.webp',
  ogImageWidth = 1200,
  ogImageHeight = 630,
  ogImageAlt = 'Old Forest Echoes — music composed in Finnish old-growth forests',
  noindex = false,
  preloadImages = [],
} = Astro.props;

const ogMimeTypes = {
  webp: 'image/webp',
  png: 'image/png',
  jpg: 'image/jpeg',
  jpeg: 'image/jpeg',
  avif: 'image/avif',
} as const satisfies Record<string, string>;

function ogImageMimeType(path: string): string {
  const ext = path.split('.').pop()?.toLowerCase() ?? '';
  const mime = ogMimeTypes[ext as keyof typeof ogMimeTypes];
  if (!mime) throw new Error(`Unsupported OG image format: .${ext} (${path})`);
  return mime;
}

const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/';
const canonicalURL = new URL(pathname, Astro.site);

const pageNameMap = Object.fromEntries(navLinks.map(({ href, label }) => [href, label]));
const pageName = pageNameMap[pathname];

const breadcrumbSchema =
  !noindex && pageName && pathname !== '/'
    ? {
        '@context': 'https://schema.org' as const,
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site?.href },
          { '@type': 'ListItem', position: 2, name: pageName, item: canonicalURL.href },
        ],
      }
    : null;

// Background is purely decorative (behind a dark overlay), so lower quality
// reduces file size without visible impact, freeing bandwidth for LCP resources
const bgSmall = await getImage({ src: forestBgSrc, width: 640, format: 'webp', quality: 50 });
const bgMedium = await getImage({ src: forestBgSrc, width: 1024, format: 'webp', quality: 50 });
const bgLarge = await getImage({ src: forestBgSrc, width: 1920, format: 'webp', quality: 50 });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <link rel="canonical" href={canonicalURL} />}
    <meta name="theme-color" content={colorBg} />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self'; frame-src https://www.youtube-nocookie.com; font-src 'self'"
    />
    <link rel="icon" href="/logo.svg" type="image/svg+xml" sizes="any" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* Open Graph — suppressed for noindex pages (e.g. 404) to avoid branded social previews of error pages */}
    {
      !noindex && (
        <>
          <meta property="og:type" content="website" />
          <meta property="og:locale" content="en_US" />
          <meta property="og:url" content={canonicalURL} />
          <meta property="og:title" content={title} />
          <meta property="og:description" content={description} />
          <meta property="og:image" content={new URL(ogImage, Astro.site)} />
          <meta property="og:image:width" content={String(ogImageWidth)} />
          <meta property="og:image:height" content={String(ogImageHeight)} />
          <meta property="og:image:type" content={ogImageMimeType(ogImage)} />
          <meta property="og:image:alt" content={ogImageAlt} />
          <meta property="og:site_name" content="Old Forest Echoes" />
        </>
      )
    }

    {/* Twitter Card */}
    {
      !noindex && (
        <>
          <meta name="twitter:card" content="summary_large_image" />
          <meta name="twitter:site" content="@oldforestechoes" />
          <meta name="twitter:title" content={title} />
          <meta name="twitter:description" content={description} />
          <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
          <meta name="twitter:image:alt" content={ogImageAlt} />
        </>
      )
    }

    {/* Fonts (self-hosted, no third-party requests) */}
    <link
      rel="preload"
      href="/fonts/Spectral-Light.woff2"
      as="font"
      type="font/woff2"
      crossorigin
      fetchpriority="high"
    />
    <link
      rel="preload"
      href="/fonts/Spectral-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
      fetchpriority="high"
    />
    <link rel="preload" href="/fonts/Leonetta-Serif.woff2" as="font" type="font/woff2" crossorigin />

    {
      /* Background image preloads and logo preload removed — the decorative background
        loads via CSS background-image after the stylesheet is parsed, and the logo is
        discovered from the HTML img tag. Neither is part of the LCP, and removing them
        frees ~84 KB of preloaded bandwidth for the critical rendering path. */
    }

    {
      preloadImages.map(({ srcset, sizes, type }) => (
        <link rel="preload" as="image" imagesrcset={srcset} imagesizes={sizes} type={type} fetchpriority="high" />
      ))
    }

    {
      /* Inline CSS eliminates the render-blocking stylesheet request, letting text
        paint as soon as the HTML arrives — critical for LCP on throttled mobile */
    }
    <Fragment set:html={`<style>${cssText}</style>`} />

    {breadcrumbSchema && <JsonLd data={breadcrumbSchema} />}
  </head>
  <body>
    <div
      class="page-background"
      aria-hidden="true"
      style={`--bg-small:url(${bgSmall.src});--bg-medium:url(${bgMedium.src});--bg-large:url(${bgLarge.src})`}
    >
    </div>
    <div class="page-overlay" aria-hidden="true"></div>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Nav />
    <main id="main-content" class="container">
      <slot />
    </main>
    <Footer />
  </body>
</html>
