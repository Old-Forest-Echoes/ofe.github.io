---
import { navLinks } from '../data/nav-links';

const normalize = (p: string) => (p.endsWith('/') ? p : p + '/');
const currentPath = Astro.url.pathname;
---

<nav class="nav" aria-label="Main">
  <div class="container">
    <a href="/" class="nav-brand" aria-label="Old Forest Echoes — Home">
      <img src="/logo.svg" alt="" class="nav-logo" width="80" height="80" />
      <span class="nav-title">Old Forest Echoes</span>
    </a>
    <button class="nav-toggle" aria-controls="nav-menu" aria-expanded="false" type="button">Menu</button>
    <ul id="nav-menu" class="nav-links" role="list">
      {
        navLinks.map(({ href, label }) => (
          <li>
            <a href={href} aria-current={normalize(currentPath) === normalize(href) ? 'page' : undefined}>
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  const navEl = document.querySelector<HTMLElement>('.nav');
  const toggleEl = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const menuEl = document.getElementById('nav-menu');

  if (navEl && toggleEl && menuEl) {
    // Aliases narrow nullable types for use in closures (openMenu, event handlers)
    const nav = navEl;
    const toggle = toggleEl;
    const menu = menuEl;
    const focusableSelector = 'a, button, [tabindex]:not([tabindex="-1"])';

    nav.classList.add('js-nav');
    let isOpen = false;

    const brand = nav.querySelector<HTMLAnchorElement>('.nav-brand');
    // Depends on .skip-link from Base.astro layout
    const skipLink = document.querySelector<HTMLAnchorElement>('.skip-link');
    // Depends on #main-content from Base.astro layout
    const mainContent = document.getElementById('main-content');
    const footer = document.querySelector('.footer');

    function openMenu() {
      isOpen = true;
      nav.classList.add('nav-open');
      document.body.classList.add('nav-scroll-lock');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.textContent = 'Close';
      menu.setAttribute('role', 'dialog');
      menu.setAttribute('aria-modal', 'true');
      menu.setAttribute('aria-label', 'Navigation');
      brand?.setAttribute('inert', '');
      skipLink?.setAttribute('inert', '');
      mainContent?.setAttribute('inert', '');
      footer?.setAttribute('inert', '');
      const firstLink = menu.querySelector('a');
      firstLink?.focus();
    }

    function closeMenu() {
      isOpen = false;
      nav.classList.remove('nav-open');
      document.body.classList.remove('nav-scroll-lock');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.textContent = 'Menu';
      menu.setAttribute('role', 'list');
      menu.removeAttribute('aria-modal');
      menu.removeAttribute('aria-label');
      brand?.removeAttribute('inert');
      skipLink?.removeAttribute('inert');
      mainContent?.removeAttribute('inert');
      footer?.removeAttribute('inert');
    }

    toggle.addEventListener('click', () => {
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        closeMenu();
        toggle.focus();
      }
    });

    // Focus trapping within open menu
    menu.addEventListener('keydown', (e) => {
      if (!isOpen || e.key !== 'Tab') return;
      const focusable = menu.querySelectorAll<HTMLElement>(focusableSelector);
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        toggle.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        toggle.focus();
      }
    });

    // Trap focus back into menu from toggle button
    toggle.addEventListener('keydown', (e) => {
      if (!isOpen || e.key !== 'Tab') return;
      if (e.shiftKey) {
        e.preventDefault();
        const links = menu.querySelectorAll('a');
        links[links.length - 1]?.focus();
      } else {
        e.preventDefault();
        const firstLink = menu.querySelector('a');
        firstLink?.focus();
      }
    });

    // Close menu if viewport grows past mobile breakpoint (e.g. device rotation)
    // to prevent inert attributes from persisting on main content.
    // 769px = 768px + 1 — complementary to global.css @media (max-width: 768px) nav rules.
    window.matchMedia('(min-width: 769px)').addEventListener('change', (e) => {
      if (e.matches && isOpen) {
        // Capture before closeMenu() modifies DOM attributes
        const hadFocusInMenu = menu.contains(document.activeElement);
        closeMenu();
        if (hadFocusInMenu) toggle.focus();
      }
    });
  }
</script>
