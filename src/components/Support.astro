---
import { newsletter, mobilepayUrl } from '../data/support';
---

<section class="section" aria-labelledby="support-heading">
  <h2 id="support-heading">Support</h2>

  <div class="support-grid">
    <div class="support-donate">
      <h3>Donate</h3>
      <p>Help protect Finnish old-growth forests. All donations go towards purchasing and preserving forest land.</p>
      {/* noopener without noreferrer: allow MobilePay to see referrer for donation tracking */}
      <a href={mobilepayUrl} class="support-btn" target="_blank" rel="noopener">Donate via MobilePay</a>
    </div>

    <div class="support-newsletter">
      <h3 id="newsletter-heading">Newsletter</h3>
      <p>Stay updated on concerts, releases, and forest conservation news.</p>
      <form action={newsletter.formAction} method="post" class="newsletter-form" aria-labelledby="newsletter-heading">
        <div class="sr-only" aria-hidden="true">
          <input type="text" name={newsletter.honeypotName} tabindex="-1" autocomplete="off" />
        </div>
        <div class="newsletter-fields">
          <label for="newsletter-email" class="sr-only">Email address</label>
          <input
            id="newsletter-email"
            type="email"
            name={newsletter.emailFieldName}
            placeholder="Email address"
            required
            autocomplete="email"
          />
          <button type="submit" class="support-btn">Subscribe</button>
        </div>
        <p class="newsletter-status" aria-live="polite"></p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>('.newsletter-form');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = form.querySelector<HTMLElement>('.newsletter-status');
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (!status || !btn) return;

      btn.disabled = true;
      status.textContent = '';
      status.classList.remove('newsletter-error');

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
        });
        if (res.ok) {
          status.textContent = 'Thank you! Please check your email to confirm your subscription.';
          form.reset();
        } else {
          status.classList.add('newsletter-error');
          status.textContent = 'Something went wrong. Please try again.';
        }
      } catch {
        status.classList.add('newsletter-error');
        status.textContent = 'Something went wrong. Please try again.';
      } finally {
        btn.disabled = false;
      }
    });
  }
</script>
