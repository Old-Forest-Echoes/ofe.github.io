---
import { contacts } from '../data/contacts';

function obfuscate(email: string): string {
  return email
    .split('')
    .map((c) => `&#${c.charCodeAt(0)};`)
    .join('');
}

function escapeAttr(str: string): string {
  return str.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}
---

<section class="section" aria-labelledby="contact-heading">
  <h2 id="contact-heading" class="sr-only">Contact</h2>
  <address class="contact-grid">
    {
      contacts.map(({ title, name, nameLanguage, email }) => (
        <p>
          <>
            <strong>{title}</strong>
            <br />
          </>
          {nameLanguage ? <span lang={nameLanguage}>{name}</span> : name}
          <br />
          <Fragment
            set:html={`<a href="&#109;&#97;&#105;&#108;&#116;&#111;&#58;${obfuscate(email)}" aria-label="${escapeAttr(email)}">${obfuscate(email)}</a>`}
          />
        </p>
      ))
    }
  </address>
</section>
