---
import Base from '../layouts/Base.astro';
import Contact from '../components/Contact.astro';
import Support from '../components/Support.astro';
import JsonLd from '../components/JsonLd.astro';
import { getCollection, render } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import type { ArtistRole } from '../content.config';
import { ORGANIZATION_ID_FRAGMENT } from '../data/organization';

const allArtists = await getCollection('artists');
const sorted = [...allArtists].sort((a, b) => a.data.order - b.data.order);

const orders = sorted.map((a) => a.data.order);
const dupes = orders.filter((o, i) => orders.indexOf(o) !== i);
if (dupes.length > 0) throw new Error(`Duplicate artist order values: ${[...new Set(dupes)].join(', ')}`);

// Key order determines page section rendering order
const roleLabels: Record<ArtistRole, string> = {
  music: 'Music',
  'land-art': 'Land Art',
  soundscapes: 'Soundscapes',
};

const roles = Object.keys(roleLabels) as ArtistRole[];

const roleJobTitles: Record<ArtistRole, string> = {
  music: 'Musician',
  'land-art': 'Visual Artist',
  soundscapes: 'Sound Artist',
};

const rendered = await Promise.all(
  sorted.map(async (artist) => {
    const { Content } = await render(artist);
    return { artist, Content, img: artist.data.image };
  }),
);

const artistNames = sorted.map((a) => a.data.name);
const formatter = new Intl.ListFormat('en', { style: 'long', type: 'conjunction' });
const artistDescription =
  artistNames.length > 0
    ? `Meet the artists of Old Forest Echoes: ${formatter.format(artistNames)}.`
    : 'Meet the artists of Old Forest Echoes.';

const siteUrl = Astro.site;
if (!siteUrl) throw new Error('Astro.site must be configured in astro.config.mjs');

function truncateDescription(body: string, maxLength = 160): string {
  const plain = body
    .replace(/<[^>]+>/g, '') // strip HTML tags
    .replace(/!\[([^\]]*)\]\([^)]+\)/g, '$1') // ![alt](url) → alt (before link regex)
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') // [text](url) → text
    .replace(/(\*{1,3})(.+?)\1/g, '$2') // **bold**/*italic* → text
    .replace(/(_{1,3})(.+?)\1/g, '$2') // __bold__/_italic_ → text
    .replace(/`([^`]+)`/g, '$1') // `code` → code
    .replace(/^#{1,6}\s+/gm, '') // headings
    .replace(/^[>-]\s+/gm, '') // blockquotes, list items
    .replace(/^\d+\.\s+/gm, '') // ordered list items
    .replace(/\s+/g, ' ')
    .trim();
  if (plain.length <= maxLength) return plain;
  return plain.slice(0, maxLength).replace(/\s\S*$/, '') + '\u2026';
}

const personSchemas = await Promise.all(
  rendered.map(async ({ artist, img }) => {
    const resolved = await getImage({ src: img, width: 800, format: 'webp' });
    return {
      '@type': 'Person',
      '@id': new URL(`/artists/#${artist.id}`, siteUrl).href,
      name: artist.data.name,
      description:
        truncateDescription(artist.body ?? '') ||
        `${artist.data.name} — ${roleJobTitles[artist.data.role]} with Old Forest Echoes`,
      url: new URL(`/artists/#${artist.id}`, siteUrl).href,
      jobTitle: roleJobTitles[artist.data.role],
      image: new URL(resolved.src, siteUrl).href,
      memberOf: {
        '@id': new URL(ORGANIZATION_ID_FRAGMENT, siteUrl).href,
      },
    };
  }),
);

const personGraph = { '@context': 'https://schema.org' as const, '@graph': personSchemas };
---

<Base title="Artists — Old Forest Echoes" description={artistDescription}>
  <JsonLd data={personGraph} />
  <section class="section" aria-labelledby="artists-heading">
    <h1 id="artists-heading">Artists</h1>
    <div class="prose">
      <p>
        Old Forest Echoes is the vision of internationally renowned singer, composer, and multi-instrumentalist Barbora
        Xu (CZ/FI), who spends prolonged periods in endangered old-growth forest areas of Finland. Conducting artistic
        research involving deep personal songwriting journeys, Barbora and her team also explore the forest to locate
        the best wilderness concert venues. The venues are transformed into a living piece of art by Wiebke Pandikow and
        become the Old Forest Echoes forest tour venues open to the public. To bring the music from the old-growth
        forests to festivals and venues, experienced sound artist Mikko H. Haapoja prepares surround system soundscape
        installations to stand alone or encapsulate a live concert. Barbora collaborates with numerous renowned artists
        such as Niklas Winter, <span lang="fi">Jenni Venäläinen</span>, and <span lang="cs">Petra Jelénková</span>
        — making every single concert a unique event.
      </p>
    </div>
  </section>

  {
    roles.map((role) => {
      const group = rendered.filter(({ artist }) => artist.data.role === role);
      if (group.length === 0) return null;
      return (
        <section class="section" id={role} aria-labelledby={`${role}-heading`}>
          <h2 id={`${role}-heading`}>{roleLabels[role]}</h2>
          {group.map(({ artist, Content, img }) => {
            return (
              <article class="artist-card" id={artist.id} aria-labelledby={`artist-${artist.id}`}>
                <Image
                  src={img}
                  alt={`Portrait of ${artist.data.name}`}
                  widths={[500, 800, 1080]}
                  sizes="(max-width: 768px) 100vw, 660px"
                  loading="lazy"
                  decoding="async"
                />
                <h3 id={`artist-${artist.id}`}>{artist.data.name}</h3>
                <div class="prose">
                  <Content />
                </div>
              </article>
            );
          })}
        </section>
      );
    })
  }

  <Support />
  <Contact />
</Base>
