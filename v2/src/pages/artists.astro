---
import Base from '../layouts/Base.astro';
import Contact from '../components/Contact.astro';
import JsonLd from '../components/JsonLd.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

const allArtists = await getCollection('artists');
const sorted = allArtists.sort((a, b) => a.data.order - b.data.order);

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpg,jpeg}', { eager: true });

const roleLabels: Record<string, string> = {
  music: 'Music',
  featured: 'Featured Artists',
  'land-art': 'Land Art',
  soundscapes: 'Soundscapes',
};

const roles = ['music', 'featured', 'land-art', 'soundscapes'] as const;

const ensembleImg = images['/src/assets/images/ensemble.jpg'];

const roleIntros: Record<string, string> = {
  featured: 'Except for live improvisations recorded during Barbora\u2019s stay in the forests, a number of acknowledged artists come onto the project as guests. Among others, a world known jazz guitarist Niklas Winter, Czech folk violinist Petra Jelénková, kantele player Jenni Venäläinen.',
};

const rendered = await Promise.all(
  sorted.map(async (artist) => {
    const { Content } = await render(artist);
    return { artist, Content };
  })
);

const personSchemas = sorted.map((artist) => ({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: artist.data.name,
  url: `https://oldforestechoes.com/artists/#${artist.data.role}`,
  jobTitle: 'Musician',
  memberOf: {
    '@type': 'Organization',
    name: 'Old Forest Echoes',
  },
}));
---

<Base title="Artists — Old Forest Echoes" description="Meet the artists of Old Forest Echoes: Barbora Xu, Ilkka Heinonen, Joni Vierre, Minna Koskenlahti, Wiebke Pandikow, and Mikko H. Haapoja.">
  {personSchemas.map((schema) => <JsonLd data={schema} />)}
  <section class="section">
    <div class="prose">
      <p>Old Forest Echoes is the vision of internationally renowned singer, composer and multi-instrumentalist Barbora Xu (CZ/FI), who spends prolonged periods in endangered old growth forest areas of Finland. Conducting artistic research involving deep personal songwriting journeys, Barbora and her team also explore the forest to locate the best wilderness concert venues. The venues are transformed into a living piece of art by Wiebke Pandikow and become the Old Forest Echoes forest tour venues open to public. To bring the music from the old growth forests to festivals and venues, experienced sound artist Mikko Haapoja prepares surround system soundscape installations to stand alone or encapsulate a live concert. Barbora collaborates with numerous renowned artists such as Niklas Winter, Ilkka Heinonen, Jenni Venäläinen, Petra Jelenkova, making every single concert a unique event.</p>
    </div>
  </section>

  {roles.map((role) => {
    const group = rendered.filter(({ artist }) => artist.data.role === role);
    if (group.length === 0) return null;
    return (
      <section class="section" id={role}>
        <h2>{roleLabels[role]}</h2>
        {role === 'featured' && ensembleImg && (
          <div class="artist-card">
            <Image src={ensembleImg.default} alt="Old Forest Echoes ensemble" widths={[500, 800, 1080, 1600]} sizes="(max-width: 768px) 100vw, 70vw" loading="lazy" />
          </div>
        )}
        {roleIntros[role] && (
          <div class="prose" style="margin-bottom: 2rem;">
            <p>{roleIntros[role]}</p>
          </div>
        )}
        {group.map(({ artist, Content }) => {
          const imgPath = `/src/assets/images/${artist.data.image}`;
          const img = images[imgPath];
          return (
            <article class="artist-card">
              {img && (
                <Image src={img.default} alt={artist.data.name} widths={[500, 800, 1080]} sizes="(max-width: 768px) 100vw, 70vw" loading="lazy" />
              )}
              <div class="prose">
                <Content />
              </div>
            </article>
          );
        })}
      </section>
    );
  })}

  <Contact />
</Base>
