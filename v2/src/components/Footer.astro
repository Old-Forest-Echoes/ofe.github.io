---
import { socialLinks } from '../data/social-links';
---

<footer class="footer">
  <div class="container">
    <div class="footer-socials">
      {socialLinks.map(({ href, label, icon, width, height, className }) => (
        <a href={href} aria-label={label} target="_blank" rel="noopener noreferrer">
          <img src={icon} alt="" class={className} width={width} height={height} />
        </a>
      ))}
    </div>
    <p class="footer-text">Old Forest Echoes &copy; {new Date().getFullYear()}</p>
  </div>
</footer>
