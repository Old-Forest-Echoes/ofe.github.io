---
const normalize = (p: string) => (p.endsWith('/') ? p : p + '/');
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'About' },
  { href: '/artists/', label: 'Artists' },
  { href: '/events/', label: 'Events' },
];
---

<nav class="nav" aria-label="Main">
  <div class="container">
    <a href="/" class="nav-brand">
      <img src="/logo.svg" alt="" class="nav-logo" width="80" height="80" />
      <span class="nav-title">Old Forest Echoes</span>
    </a>
    <button class="nav-toggle" aria-controls="nav-menu" aria-expanded="false" type="button">Menu</button>
    <ul id="nav-menu" class="nav-links">
      {links.map(({ href, label }) => (
        <li>
          <a href={href} aria-current={normalize(currentPath) === normalize(href) ? 'page' : undefined}>
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const nav = document.querySelector('.nav') as HTMLElement;
  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
  const menu = document.getElementById('nav-menu') as HTMLUListElement;

  if (nav && toggle && menu) {
    let isOpen = false;

    const brand = nav.querySelector('.nav-brand') as HTMLAnchorElement | null;
    const mainContent = document.getElementById('main-content');
    const footer = document.querySelector('.footer');

    function openMenu() {
      isOpen = true;
      nav.classList.add('nav-open');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.textContent = 'Close';
      brand?.setAttribute('inert', '');
      mainContent?.setAttribute('inert', '');
      footer?.setAttribute('inert', '');
      const firstLink = menu.querySelector('a');
      firstLink?.focus();
    }

    function closeMenu() {
      isOpen = false;
      nav.classList.remove('nav-open');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.textContent = 'Menu';
      brand?.removeAttribute('inert');
      mainContent?.removeAttribute('inert');
      footer?.removeAttribute('inert');
    }

    toggle.addEventListener('click', () => {
      isOpen ? closeMenu() : openMenu();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        closeMenu();
        toggle.focus();
      }
    });

    // Focus trapping within open menu
    menu.addEventListener('keydown', (e) => {
      if (!isOpen || e.key !== 'Tab') return;
      const focusable = menu.querySelectorAll('a');
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        toggle.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        toggle.focus();
      }
    });

    // Trap focus back into menu from toggle button
    toggle.addEventListener('keydown', (e) => {
      if (!isOpen || e.key !== 'Tab') return;
      if (e.shiftKey) return;
      e.preventDefault();
      const firstLink = menu.querySelector('a');
      firstLink?.focus();
    });
  }
</script>
